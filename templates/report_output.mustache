{{!
    This file is part of Moodle - https://moodle.org/

    @template tool_phpunitchecker/report_output

    Template for rendering parsed PHPUnit JUnit XML report output.
}}

<style>
    .tool-phpunitchecker-report .accordion-button::after {
        display: none;
    }

    .tool-phpunitchecker-report .phpunitchecker-accordion-icon {
        transition: transform 0.2s ease-in-out;
        display: inline-block;
        width: 1rem;
    }

    .tool-phpunitchecker-report .accordion-button:not(.collapsed) .phpunitchecker-accordion-icon {
        transform: rotate(90deg);
    }

    .tool-phpunitchecker-report pre {
        white-space: pre-wrap;
    }
</style>

<div class="tool-phpunitchecker-report">

    <div class="alert {{statusclass}} mb-3">
        <strong>{{statustext}}</strong>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <strong>{{#str}} overallsummary, tool_phpunitchecker {{/str}}</strong>
        </div>

        <div class="card-body">
            <div class="row gy-2">
                <div class="col-md-3">
                    <div class="border rounded p-2 h-100">
                        <div class="text-muted small">
                            {{#str}} totaltests, tool_phpunitchecker {{/str}}
                        </div>
                        <div class="h5 mb-0">
                            {{total}}
                        </div>
                    </div>
                </div>

                {{#summaryitems}}
                    <div class="col-md-3">
                        <div class="border rounded p-2 h-100">
                            <div class="text-muted small">
                                {{label}}
                            </div>
                            <div class="h5 mb-0 {{class}}">
                                {{value}}
                            </div>
                        </div>
                    </div>
                {{/summaryitems}}
            </div>
        </div>
    </div>

    <h3 class="h5 mb-3">
        {{#str}} componentsuites, tool_phpunitchecker {{/str}}
    </h3>

    <div class="accordion mb-3" id="phpunitchecker-component-accordion">
        {{#componentsuites}}
            <div class="accordion-item border {{statusclass}} mb-2">

                <h2 class="accordion-header" id="phpunitchecker-component-heading-{{uniqid}}">
                    <button class="accordion-button {{^hasproblems}}collapsed{{/hasproblems}} {{headerclass}}"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#phpunitchecker-component-collapse-{{uniqid}}"
                            aria-expanded="{{#hasproblems}}true{{/hasproblems}}{{^hasproblems}}false{{/hasproblems}}"
                            aria-controls="phpunitchecker-component-collapse-{{uniqid}}">

                        <span class="phpunitchecker-accordion-icon me-2" aria-hidden="true">▸</span>

                        <div class="w-100 me-3">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <strong>{{name}}</strong>
                                </div>

                                <div class="text-nowrap">
                                    <span class="badge bg-success"
                                          title="{{#str}} passedtests, tool_phpunitchecker {{/str}}">
                                        ✓ {{passed}}
                                    </span>

                                    <span class="badge bg-danger"
                                          title="{{#str}} failedtests, tool_phpunitchecker {{/str}}">
                                        ✗ {{failed}}
                                    </span>

                                    <span class="badge bg-danger"
                                          title="{{#str}} errortests, tool_phpunitchecker {{/str}}">
                                        ! {{errors}}
                                    </span>

                                    <span class="badge bg-warning text-dark"
                                          title="{{#str}} warningtests, tool_phpunitchecker {{/str}}">
                                        ⚠ {{warnings}}
                                    </span>

                                    <span class="badge bg-info text-dark"
                                          title="{{#str}} noticetests, tool_phpunitchecker {{/str}}">
                                        N {{notices}}
                                    </span>

                                    <span class="badge bg-secondary"
                                          title="{{#str}} skippedtests, tool_phpunitchecker {{/str}}">
                                        S {{skipped}}
                                    </span>

                                    <span class="badge bg-dark"
                                          title="{{#str}} totaltests, tool_phpunitchecker {{/str}}">
                                        {{total}}
                                    </span>
                                </div>
                            </div>
                        </div>
                    </button>
                </h2>

                <div id="phpunitchecker-component-collapse-{{uniqid}}"
                     class="accordion-collapse collapse {{#hasproblems}}show{{/hasproblems}}"
                     aria-labelledby="phpunitchecker-component-heading-{{uniqid}}"
                     data-bs-parent="#phpunitchecker-component-accordion">

                    <div class="accordion-body">

                        <div class="card mb-3">
                            <div class="card-header">
                                <strong>{{#str}} componentsummary, tool_phpunitchecker {{/str}}</strong>
                            </div>

                            <div class="card-body">
                                <div class="row gy-2">
                                    <div class="col-md-3">
                                        <div class="border rounded p-2 h-100">
                                            <div class="text-muted small">
                                                {{#str}} totaltests, tool_phpunitchecker {{/str}}
                                            </div>
                                            <div class="h5 mb-0">
                                                {{total}}
                                            </div>
                                        </div>
                                    </div>

                                    {{#summaryitems}}
                                        <div class="col-md-3">
                                            <div class="border rounded p-2 h-100">
                                                <div class="text-muted small">
                                                    {{label}}
                                                </div>
                                                <div class="h5 mb-0 {{class}}">
                                                    {{value}}
                                                </div>
                                            </div>
                                        </div>
                                    {{/summaryitems}}
                                </div>
                            </div>
                        </div>

                        {{#testsuites}}
                            <div class="card mb-3 {{statusclass}}">
                                <div class="card-header">
                                    <div class="d-flex justify-content-between align-items-start gap-3">
                                        <div>
                                            <strong class="{{headerclass}}">{{name}}</strong>

                                            <div class="small text-muted">
                                                {{classname}}
                                            </div>

                                            {{#hasfile}}
                                                <div class="small text-muted mt-1">
                                                    {{file}}
                                                </div>
                                            {{/hasfile}}
                                        </div>

                                        <div class="text-nowrap">
                                            <span class="badge bg-success">✓ {{passed}}</span>
                                            <span class="badge bg-danger">✗ {{failed}}</span>
                                            <span class="badge bg-danger">! {{errors}}</span>
                                            <span class="badge bg-warning text-dark">⚠ {{warnings}}</span>
                                            <span class="badge bg-info text-dark">N {{notices}}</span>
                                            <span class="badge bg-secondary">S {{skipped}}</span>
                                            <span class="badge bg-dark">{{total}}</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="card-body">
                                    <ul class="list-group">
                                        {{#testcases}}
                                            <li class="list-group-item">
                                                <div class="d-flex align-items-start gap-2">

                                                    <span class="{{badgeclass}} mt-1">
                                                        {{statusicon}}
                                                    </span>

                                                    <div class="flex-grow-1">
                                                        <div class="d-flex justify-content-between align-items-start gap-3">
                                                            <div>
                                                                <strong class="{{statusclass}}">
                                                                    {{name}}
                                                                </strong>

                                                                <small class="text-muted ms-1">
                                                                    {{statustext}}
                                                                </small>
                                                            </div>

                                                            <div class="small text-muted text-nowrap">
                                                                {{#hastime}}
                                                                    {{time}}s
                                                                {{/hastime}}

                                                                {{#hasassertions}}
                                                                    · {{assertions}} {{#str}}
                                                                    assertions, tool_phpunitchecker {{/str}}
                                                                {{/hasassertions}}
                                                            </div>
                                                        </div>

                                                        {{#hasline}}
                                                            <div class="small text-muted mt-1">
                                                                {{#str}} line, tool_phpunitchecker {{/str}}: {{line}}
                                                            </div>
                                                        {{/hasline}}

                                                        {{#hasfile}}
                                                            <div class="small text-muted">
                                                                {{file}}
                                                            </div>
                                                        {{/hasfile}}

                                                        {{#hastype}}
                                                            <div class="small text-danger mt-2">
                                                                <strong>{{type}}</strong>
                                                            </div>
                                                        {{/hastype}}

                                                        {{#hasdetails}}
                                                            <details class="mt-2">
                                                                <summary class="small text-muted">
                                                                    {{#str}} details, tool_phpunitchecker {{/str}}
                                                                </summary>

                                                                <pre class="mt-2 p-2 bg-light border rounded small mb-0">{{details}}</pre>
                                                            </details>
                                                        {{/hasdetails}}
                                                    </div>
                                                </div>
                                            </li>
                                        {{/testcases}}
                                    </ul>
                                </div>
                            </div>
                        {{/testsuites}}

                    </div>
                </div>
            </div>
        {{/componentsuites}}
    </div>

    {{^componentsuites}}
        <div class="alert alert-warning">
            {{#str}} noreportdatafound, tool_phpunitchecker {{/str}}
        </div>
    {{/componentsuites}}

</div>